{
  "name": "pipeline",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "tsx src/run.ts",
    "dry-run": "DRY_RUN=true tsx src/run.ts",
    "dev": "tsx watch src/run.ts",
    "retention": "tsx src/retention.ts",
    "check-deps": "tsx src/scripts/deps-tracker.ts",
    "worker": "tsx src/queue-worker.ts",
    "worker:enqueue": "tsx src/queue-worker.ts --enqueue",
    "worker:status": "tsx src/queue-worker.ts --status",
    "worker:requeue": "tsx src/queue-worker.ts --requeue-stale",
    "scrape": "tsx src/agents/maps-scraper.ts",
    "scrape:hvac": "tsx src/agents/maps-scraper.ts --niche hvac --city \"Austin\" --state TX --count 100",
    "scrape:daily": "tsx src/scripts/daily-scrape.ts",
    "scrape:now": "SCRAPE_TARGET=100 tsx src/scripts/daily-scrape.ts",
    "sheets:setup": "tsx src/scripts/setup-sheets.ts",
    "cron:install": "bash scripts/setup-cron.sh",
    "logs": "tail -f logs/daily-scrape.log",
    "outreach": "tsx src/scripts/send-outreach.ts",
    "outreach:dry": "SMS_DRY_RUN=true tsx src/scripts/send-outreach.ts",
    "outreach:t1": "OUTREACH_TIER=tier1 tsx src/scripts/send-outreach.ts",
    "outreach:t2": "OUTREACH_TIER=tier2 tsx src/scripts/send-outreach.ts",
    "api:deploy": "cd ../api && npx wrangler deploy",
    "repair": "tsx src/scripts/repair-stuck-leads.ts"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "pg-boss": "^10.4.2",
    "playwright": "^1.60.0",
    "tweetsodium": "^0.0.4",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
