# Google AI (Gemini — free 1,500 req/day)
GOOGLE_AI_API_KEY=AIza...

# Google Places API (New) — enable at console.cloud.google.com
GOOGLE_PLACES_API_KEY=AIza...

# Firecrawl cloud — firecrawl.dev (free 500 scrapes/month)
FIRECRAWL_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# GitHub
GITHUB_TOKEN=ghp_...

# Cloudflare Pages
# Token: dash.cloudflare.com → My Profile → API Tokens → Create Token → "Edit Cloudflare Workers"
# Account ID: dash.cloudflare.com → Workers & Pages → right sidebar
CLOUDFLARE_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# Pipeline API URL (leave blank until you deploy the pipeline as an API)
PIPELINE_API_URL=

# Resend
RESEND_API_KEY=re_...
OUTREACH_FROM_EMAIL=hello@yourdomain.com

# Neon (managed serverless Postgres — neon.tech, free tier)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Pipeline config
# NICHE options: hvac | roofing | dentist | medspa | lawfirm | remodeling | cleaning | junk-removal | daycare | auto-detailing | restaurant
NICHE=hvac
LOCATION=Tracy, CA
CITY=Tracy
STATE=CA
COUNT=10
TEMPLATE_OWNER=ranjeetsinghai79
TEMPLATE_REPO=websitedeveloper
DEPLOY_OWNER=ranjeetsinghai79
DRY_RUN=true

# fal.ai — Flux Pro 1.1 image generation + Kling 1.6 Pro video generation (PRIMARY)
# Get key at fal.ai — $10 free credit on signup. ~$0.04 per image, ~$0.05 per video.
FAL_KEY=fal_...

# Hugging Face — Z-Image-Turbo + FLUX.1-schnell (FREE fallback if no FAL_KEY)
HUGGING_FACE_API_KEY=hf_...

# Google Service Account (for Sheets + GMB + GSC — optional)
# Save JSON file from GCP Console → Service Accounts → Keys → JSON as pipeline/service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# Google My Business (optional)
GBP_ACCOUNT_ID=accounts/123456789
GBP_LOCATION_ID=locations/987654321

# Google Sheets (optional — lead capture)
LEADS_SHEET_ID=

# Business owner email
BUSINESS_OWNER_EMAIL=pavan.harati@gmail.com

# ── Sales Funnel ────────────────────────────────────────────────────────────

# Twilio SMS (outreach + AI conversation agent)
# Get at twilio.com — $15 starter credit, ~$0.0079/SMS
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Stripe (payment links + webhooks)
# Get at stripe.com — no monthly fee, 2.9% + 30¢ per transaction
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
WEBSITE_PRICE_ONE_TIME=29900   # cents = $299 one-time
WEBSITE_PRICE_MONTHLY=4900     # cents = $49/month hosting

# Calendly (meeting scheduling)
# Your personal Calendly link for 15-min discovery calls
CALENDLY_URL=https://calendly.com/your-name/15min

# ── Queue / Scale ───────────────────────────────────────────────────────────

# Parallel workers (how many sites to generate simultaneously)
# 3 = safe default, 10 = aggressive (watch fal.ai + Gemini rate limits)
WORKER_CONCURRENCY=3
